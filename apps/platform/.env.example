# Database
DATABASE_URL=postgresql://user:password@localhost:5432/platform

# Better Auth
BETTER_AUTH_SECRET=your-secret-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3100

# Social Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Shared service token. Products use this to authenticate with the platform
# for trusted server-to-server calls (entitlements, billing). Generate with
# `openssl rand -hex 32`.
PLATFORM_SERVICE_TOKEN=your-service-token

# Port the HTTP server listens on (default 3100)
PORT=3100
