# Database (Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/photocall

# Better Auth
BETTER_AUTH_SECRET=
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OAuth Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# S3 Storage
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=photocall
S3_PUBLIC_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=

# Vercel Cron
CRON_SECRET=

# Unified Platform (@sferadev/platform). Leave blank to disable platform-backed
# entitlement checks and metered usage reporting (falls back to local limits).
PLATFORM_SERVICE_URL=
PLATFORM_PRODUCT_ID=photocall
PLATFORM_SERVICE_TOKEN=
