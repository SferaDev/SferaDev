# Database (photocall-owned application data only — auth/billing live on the platform)
DATABASE_URL=postgresql://user:password@localhost:5432/photocall

# Site URL (used for absolute URLs in emails, OAuth callbacks, and share links)
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# S3 Storage (kiosk photos, event/org logos, templates)
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=photocall
S3_PUBLIC_URL=

# Vercel Cron
CRON_SECRET=

# Unified platform (@sferadev/platform). All identity, billing, and
# entitlement state lives here — photocall talks to it through the SDK and
# the /api/auth/* reverse proxy.
PLATFORM_SERVICE_URL=http://localhost:3100
PLATFORM_PRODUCT_ID=photocall
PLATFORM_SERVICE_TOKEN=

# Public plan id used when starting Stripe Checkout from the billing page.
# Matches a plan registered with the platform service.
NEXT_PUBLIC_PHOTOCALL_PRO_PLAN_ID=photocall_pro
